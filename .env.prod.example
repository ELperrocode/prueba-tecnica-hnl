# ── Production environment variables ──
# Copy this file to .env and fill in real values before deploying.

# Your domain (or Droplet IP for testing without HTTPS)
DOMAIN=YOUR_DROPLET_IP

# PostgreSQL (use a strong random password)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your-real-key-here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
