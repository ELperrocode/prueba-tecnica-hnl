# Caddyfile — automatic HTTPS reverse proxy
#
# Caddy automatically obtains Let's Encrypt certificates for the DOMAIN.
# For local testing (IP or localhost), uncomment: auto_https off

{$DOMAIN:localhost} {
	# Frontend (serves the React SPA + proxies /api to backend)
	# Auto HTTPS enabled — Caddy obtains Let's Encrypt certificate
	reverse_proxy frontend:80

	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Gzip compression
	encode gzip

	# Access logs
	log {
		output stdout
	}
}
